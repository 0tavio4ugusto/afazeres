generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model tarefas {
  idtarefa     Int      @default(autoincrement())
  idusuario    Int
  titulotarefa String?  @db.VarChar(120)
  desctarefa   String?  @db.VarChar(500)
  statustarefa Int?
  usuarios     usuarios @relation(fields: [idusuario], references: [idusuario], onDelete: NoAction, onUpdate: NoAction, map: "fkusuario")

  @@id([idtarefa, idusuario])
  @@index([idusuario], map: "fkusuario")
}

model usuarios {
  idusuario Int       @id @default(autoincrement())
  nome      String?   @db.VarChar(45)
  email     String?   @db.VarChar(45)
  senha     String?   @db.VarChar(45)
  tarefas   tarefas[]
}
